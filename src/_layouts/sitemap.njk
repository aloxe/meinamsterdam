<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% for item in collections.all %}
    {% if item.data.excludeFromSitemap != true  %}{% if item.url !== false  %}
      <url>
        <loc>{{ meta.url }}{{ item.url }}</loc> 
      </url>
    {% endif %}{% endif %}
  {% endfor %}
</urlset>
